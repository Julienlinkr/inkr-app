# ============ INKR CONFIG ============
# Copie ce fichier en .env et remplis les valeurs

# Clé secrète JWT (mets n'importe quelle longue chaîne aléatoire)
JWT_SECRET=inkr_super_secret_change_moi_2024

# Port du serveur (laisser 3000)
PORT=3000

# ============ EMAIL (Gmail) ============
# Active "Mots de passe d'application" dans ton compte Google
# https://myaccount.google.com/apppasswords
EMAIL_USER=ton.email@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM=inkr <ton.email@gmail.com>

# ============ SMS (Twilio) ============
# Inscription gratuite sur twilio.com (15$ de crédit offert)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE=+1xxxxxxxxxx

# ============ META (Instagram + Facebook DM) ============
# Créer une app sur developers.facebook.com
# Produits à ajouter : Instagram Graph API + Facebook Login
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/auth/meta/callback
